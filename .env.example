# Copy this file to `.env` and fill in your own values.
# Never commit your real `.env` file.

# Base URL of the Odoo instance (no trailing slash).
ODOO_URL=https://your-odoo-host.example.com

# Database name.
ODOO_DB=your_database_name

# Odoo user login. Use a dedicated READ-ONLY user for safety.
ODOO_USERNAME=readonly_audit_user

# Password or API key for the user above.
ODOO_PASSWORD=replace_me
